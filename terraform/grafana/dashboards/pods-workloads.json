{
  "title": "Pods & Workloads",
  "uid": "pods-workloads",
  "schemaVersion": 40,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "tags": ["homelab", "pods"],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "query": "label_values(kube_namespace_created, namespace)",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "refresh": 1,
        "includeAll": true,
        "multi": true
      },
      {
        "name": "pod",
        "type": "query",
        "query": "label_values(kube_pod_info{namespace=~\"$namespace\"}, pod)",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "refresh": 1,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "type": "graph",
      "title": "CPU Usage by Namespace",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{
        "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\",container!=\"\",pod!=\"\"}[5m])) by(namespace)",
        "legendFormat": "{{ namespace }}",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }],
      "yaxes": [{ "format": "short" }, {}]
    },
    {
      "type": "graph",
      "title": "Memory Usage by Namespace",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{
        "expr": "sum(container_memory_working_set_bytes{namespace=~\"$namespace\",container!=\"\",pod!=\"\"}) by(namespace)",
        "legendFormat": "{{ namespace }}",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }],
      "yaxes": [{ "format": "bytes" }, {}]
    },
    {
      "type": "table",
      "title": "Pod Restarts",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{
        "expr": "max by(namespace, pod) (kube_pod_container_status_restarts_total{namespace=~\"$namespace\",pod=~\"$pod\"})",
        "legendFormat": "",
        "format": "table",
        "instant": true,
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }]
    },
    {
      "type": "graph",
      "title": "CPU vs Requests (Top Pending Pods)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{
        "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\",container!=\"\",pod=~\"$pod\"}[5m])) by(pod) / sum(kube_pod_container_resource_requests{namespace=~\"$namespace\",pod=~\"$pod\",resource=\"cpu\"}) by(pod)",
        "legendFormat": "{{ pod }}",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }],
      "yaxes": [{ "format": "percentunit", "min": 0 }, {}]
    },
    {
      "type": "stat",
      "title": "OOMKilled Containers (24h)",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "targets": [{
        "expr": "sum(increase(kube_pod_container_status_terminated_reason{reason=\"OOMKilled\"}[24h]))",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }]
    },
    {
      "type": "stat",
      "title": "Pending Pods",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 16 },
      "targets": [{
        "expr": "count(kube_pod_status_phase{phase=\"Pending\"})",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }]
    },
    {
      "type": "stat",
      "title": "Running Pods",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 16 },
      "targets": [{
        "expr": "count(kube_pod_status_phase{phase=\"Running\"})",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }]
    }
  ]
}
