{
  "title": "Traefik",
  "uid": "traefik",
  "schemaVersion": 40,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "tags": ["homelab", "traefik"],
  "panels": [
    {
      "type": "stat",
      "title": "Requests/s",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{
        "expr": "sum(rate(traefik_service_request_duration_seconds_count[5m]))",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }],
      "unit": "reqps"
    },
    {
      "type": "stat",
      "title": "p95 Latency",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(traefik_service_request_duration_seconds_bucket[5m])) by(le))",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }],
      "unit": "s"
    },
    {
      "type": "stat",
      "title": "p99 Latency",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(traefik_service_request_duration_seconds_bucket[5m])) by(le))",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }],
      "unit": "s"
    },
    {
      "type": "stat",
      "title": "4xx Rate",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{
        "expr": "sum(rate(traefik_service_requests_total{code=~\"4..\"}[5m]))",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }],
      "unit": "reqps"
    },
    {
      "type": "stat",
      "title": "5xx Rate",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [{
        "expr": "sum(rate(traefik_service_requests_total{code=~\"5..\"}[5m]))",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }],
      "unit": "reqps"
    },
    {
      "type": "stat",
      "title": "2xx Rate",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [{
        "expr": "sum(rate(traefik_service_requests_total{code=~\"2..\"}[5m]))",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }],
      "unit": "reqps"
    },
    {
      "type": "graph",
      "title": "Request Rate by EntryPoint",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{
        "expr": "sum(rate(traefik_service_requests_total[5m])) by(entrypoint)",
        "legendFormat": "{{ entrypoint }}",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }]
    },
    {
      "type": "graph",
      "title": "Latency (p50, p95, p99)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(traefik_service_request_duration_seconds_bucket[5m])) by(le))",
          "legendFormat": "p50",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(traefik_service_request_duration_seconds_bucket[5m])) by(le))",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(traefik_service_request_duration_seconds_bucket[5m])) by(le))",
          "legendFormat": "p99",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "yaxes": [{ "format": "s" }, {}]
    },
    {
      "type": "graph",
      "title": "Status Codes",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(traefik_service_requests_total{code=~\"2..\"}[5m]))",
          "legendFormat": "2xx",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(traefik_service_requests_total{code=~\"4..\"}[5m]))",
          "legendFormat": "4xx",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(traefik_service_requests_total{code=~\"5..\"}[5m]))",
          "legendFormat": "5xx",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    }
  ]
}
